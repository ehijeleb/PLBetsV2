# ─── Backend ──────────────────────────────────────────────────────────────────

# Free key from https://www.football-data.org (sign up, then "Account" → "API Token").
# Without a key, the dashboard still runs but live fixtures / standings will be empty.
FOOTBALL_DATA_API_KEY=

# SQLAlchemy connection string for the prediction-history database.
# Default is a SQLite file at backend/plbets.db.
DATABASE_URL=sqlite:///./plbets.db

# Comma-separated list of origins allowed by CORS.
# Add your deployed frontend host(s) here.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ─── Frontend ─────────────────────────────────────────────────────────────────

# Base URL the browser uses to call the API. Leave as default when running
# backend + frontend on the same machine via `npm run dev` / uvicorn.
NEXT_PUBLIC_API_URL=http://localhost:8000
